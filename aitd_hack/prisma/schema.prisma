// ==========================================
// Prisma Generator & Datasource Configuration
// ==========================================
generator client {
  provider        = "prisma-client-js"
  engineType      = "library"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
  // Enables pgvector extension automatically
  extensions = [vector]
}

// ==========================================
// User Management
// ==========================================
model Profile {
  id            String         @id // Usually tied to the Auth provider (e.g., Clerk user ID)
  email         String         @unique
  username      String?
  createdAt     DateTime       @default(now())
  
  items         Item[]         // Items reported by the user
  notifications Notification[] // Notifications received by the user
  comments      Comment[]      // Comments made by the user
  claims        Claim[]        // Claims made by the user
}

// ==========================================
// Categorization
// ==========================================
model Category {
  id    Int     @id @default(autoincrement())
  name  String  @unique // e.g., "Electronics", "Clothing", "Keys"
  
  items Item[]
}

// ==========================================
// Core Entities: Lost & Found Items
// ==========================================
model Item {
  id            String    @id @default(uuid())
  title         String    // Brief title of the item
  description   String?   // Detailed description for matching
  imageUrl      String    // URL to the image stored in Supabase Storage
  type          String    // Indicates if the item is "lost" or "found"
  status        String    @default("active") // Lifecycle status: "active", "matched", "returned"
  locationName  String?   // Where the item was lost/found
  
  userId        String
  user          Profile   @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  categoryId    Int?
  category      Category? @relation(fields: [categoryId], references: [id])
  
  // Relationships for item matching
  lostMatches   Match[]   @relation("LostItem")
  foundMatches  Match[]   @relation("FoundItem")
  
  comments      Comment[] // Comments on this item
  claims        Claim[]   // Claims made on this item
  
  // Vector embedding representing the image/text for AI similarity matching
  embedding     Unsupported("vector(768)")?
  
  createdAt     DateTime  @default(now())
  
  @@index([userId])
  @@index([type])
  @@index([status])
}

// ==========================================
// Matching System
// ==========================================
model Match {
  id              String   @id @default(uuid())
  lostItemId      String
  foundItemId     String
  similarityScore Float    // AI-calculated confidence score (0-100)
  status          String   @default("pending") // "pending", "confirmed", "rejected"
  
  lostItem        Item     @relation("LostItem", fields: [lostItemId], references: [id], onDelete: Cascade)
  foundItem       Item     @relation("FoundItem", fields: [foundItemId], references: [id], onDelete: Cascade)
  
  notification    Notification?
  
  createdAt       DateTime @default(now())
  
  // Ensure a specific lost and found item pair is only matched once
  @@unique([lostItemId, foundItemId])
  @@index([status])
  @@index([similarityScore])
}

// ==========================================
// Notifications
// ==========================================
model Notification {
  id        String   @id @default(uuid())
  title     String   // Notification title
  message   String   // Notification body
  isRead    Boolean  @default(false)
  
  userId    String
  user      Profile  @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  matchId   String?  @unique
  match     Match?   @relation(fields: [matchId], references: [id], onDelete: Cascade)
  
  createdAt DateTime @default(now())
  
  @@index([userId])
  @@index([isRead])
}

// ==========================================
// Comments
// ==========================================
model Comment {
  id        String   @id @default(uuid())
  text      String   // The content of the comment
  
  itemId    String
  item      Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  
  userId    String
  user      Profile  @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  createdAt DateTime @default(now())
  
  @@index([itemId])
  @@index([userId])
}

// ==========================================
// Claims
// ==========================================
model Claim {
  id        String   @id @default(uuid())
  message   String   // The content of the claim/proof
  status    String   @default("pending") // pending, approved, rejected
  
  itemId    String
  item      Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  
  userId    String
  user      Profile  @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  createdAt DateTime @default(now())
  
  @@index([itemId])
  @@index([userId])
  @@index([status])
}